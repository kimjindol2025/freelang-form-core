// FreeLang Direct-Bind Form Engine
// Phase 4: Memory Pool (Object Pool Pattern)
// GC 압력 제거, 성능 안정화
// 2026-03-08

// ========================================
// ValidationResult 풀
// ========================================

struct ValidationResultPool {
    pool: [ValidationResult],
    pool_size: int,
    in_use: int = 0,
    total_acquired: i64 = 0,
    total_released: i64 = 0,

    fn __init__(initial_size: int = 100) {
        this.pool_size = initial_size
        this.pool = []

        // 사전 할당
        for i in 0..initial_size {
            this.pool.push(ValidationResult{
                is_valid: true,
                errors: []
            })
        }
    }

    fn acquire() -> ValidationResult {
        this.total_acquired += 1

        if this.pool.length > 0 {
            this.in_use += 1
            return this.pool.pop()
        } else {
            // 풀 부족 시 새로 할당
            print("⚠️  메모리 풀 부족: 새로 할당")
            return ValidationResult{
                is_valid: true,
                errors: []
            }
        }
    }

    fn release(result: ValidationResult) {
        this.total_released += 1

        // 재사용을 위해 초기화
        result.is_valid = true
        result.errors = []

        this.pool.push(result)
        this.in_use -= 1
    }

    fn release_batch(results: [ValidationResult]) {
        for result in results {
            this.release(result)
        }
    }

    fn get_stats() -> map<string, any> {
        return {
            "pool_size": this.pool.length,
            "in_use": this.in_use,
            "total_size": this.pool_size,
            "total_acquired": this.total_acquired,
            "total_released": this.total_released,
            "utilization": (this.in_use as f64) / (this.pool_size as f64)
        }
    }

    fn print_stats() {
        let stats = this.get_stats()
        print("【ValidationResult Pool】")
        print("  Size: " + (stats["pool_size"] as string) + "/" + (stats["total_size"] as string))
        print("  In Use: " + (stats["in_use"] as string))
        print("  Acquired: " + (stats["total_acquired"] as string))
        print("  Released: " + (stats["total_released"] as string))
        print("  Utilization: " + ((stats["utilization"] as f64) * 100.0 as string) + "%\n")
    }
}

// ========================================
// ValidationError 풀
// ========================================

struct ValidationErrorPool {
    pool: [ValidationError],
    pool_size: int,
    in_use: int = 0,

    fn __init__(initial_size: int = 500) {
        this.pool_size = initial_size
        this.pool = []

        for i in 0..initial_size {
            this.pool.push(ValidationError{
                field: "",
                code: "",
                message: ""
            })
        }
    }

    fn acquire() -> ValidationError {
        if this.pool.length > 0 {
            this.in_use += 1
            return this.pool.pop()
        } else {
            print("⚠️  에러 풀 부족: 새로 할당")
            return ValidationError{
                field: "",
                code: "",
                message: ""
            }
        }
    }

    fn release(error: ValidationError) {
        error.field = ""
        error.code = ""
        error.message = ""

        this.pool.push(error)
        this.in_use -= 1
    }

    fn release_batch(errors: [ValidationError]) {
        for error in errors {
            this.release(error)
        }
    }

    fn get_stats() -> map<string, any> {
        return {
            "pool_size": this.pool.length,
            "in_use": this.in_use,
            "total_size": this.pool_size
        }
    }
}

// ========================================
// FieldValidator 풀
// ========================================

struct FieldValidatorPool {
    pool: [FieldValidator],
    pool_size: int,
    in_use: int = 0,

    fn __init__(initial_size: int = 50) {
        this.pool_size = initial_size
        this.pool = []

        // 초기 할당은 생략 (FieldValidator는 복잡)
    }

    fn acquire(field_name: string, field_type: string) -> FieldValidator {
        if this.pool.length > 0 {
            this.in_use += 1
            let validator = this.pool.pop()
            validator.field_name = field_name
            validator.type = field_type
            return validator
        } else {
            return FieldValidator{
                field_name: field_name,
                field_index: 0,
                type: field_type,
                constraints: [],
                current_value: null,
                last_error: null
            }
        }
    }

    fn release(validator: FieldValidator) {
        validator.field_name = ""
        validator.type = ""
        validator.constraints = []
        validator.current_value = null
        validator.last_error = null

        this.pool.push(validator)
        this.in_use -= 1
    }
}

// ========================================
// 풀 매니저 (통합)
// ========================================

struct PoolManager {
    result_pool: ValidationResultPool,
    error_pool: ValidationErrorPool,
    validator_pool: FieldValidatorPool,

    total_gc_prevented: i64 = 0,

    fn __init__() {
        this.result_pool = ValidationResultPool{ pool_size: 100 }
        this.error_pool = ValidationErrorPool{ pool_size: 500 }
        this.validator_pool = FieldValidatorPool{ pool_size: 50 }
    }

    fn acquire_result() -> ValidationResult {
        return this.result_pool.acquire()
    }

    fn release_result(result: ValidationResult) {
        this.result_pool.release(result)
        this.total_gc_prevented += 1
    }

    fn acquire_error() -> ValidationError {
        return this.error_pool.acquire()
    }

    fn release_error(error: ValidationError) {
        this.error_pool.release(error)
        this.total_gc_prevented += 1
    }

    fn acquire_validator(field_name: string, field_type: string) -> FieldValidator {
        return this.validator_pool.acquire(field_name, field_type)
    }

    fn release_validator(validator: FieldValidator) {
        this.validator_pool.release(validator)
    }

    fn get_total_stats() -> map<string, any> {
        return {
            "result_pool": this.result_pool.get_stats(),
            "error_pool": this.error_pool.get_stats(),
            "validator_pool": this.validator_pool.pool_size,
            "total_gc_prevented": this.total_gc_prevented
        }
    }

    fn print_all_stats() {
        print("\n=== 메모리 풀 통계 ===\n")
        this.result_pool.print_stats()

        let error_stats = this.error_pool.get_stats()
        print("【ValidationError Pool】")
        print("  Size: " + (error_stats["pool_size"] as string) + "/" + (error_stats["total_size"] as string))
        print("  In Use: " + (error_stats["in_use"] as string) + "\n")

        print("【GC 방지】")
        print("  Total Objects Reused: " + (this.total_gc_prevented as string) + "\n")
    }
}

// ========================================
// 성능 분석
// ========================================

struct PoolPerformanceAnalyzer {
    fn benchmark_with_pool(iterations: int) -> i64 {
        let pool = PoolManager{}
        let start = __current_time_ms()

        for i in 0..iterations {
            let result = pool.acquire_result()
            let error = pool.acquire_error()

            // 사용
            result.is_valid = false
            result.errors.push(error)

            // 반환
            result.errors.pop()
            pool.release_error(error)
            pool.release_result(result)
        }

        return __current_time_ms() - start
    }

    fn benchmark_without_pool(iterations: int) -> i64 {
        let start = __current_time_ms()

        for i in 0..iterations {
            let result = ValidationResult{ is_valid: true, errors: [] }
            let error = ValidationError{ field: "test", code: "TEST", message: "test" }

            result.is_valid = false
            result.errors.push(error)

            result.errors.pop()
            // GC가 자동으로 수집
        }

        return __current_time_ms() - start
    }

    fn compare() {
        print("=== 메모리 풀 vs 일반 할당 ===\n")

        let iterations = 10000

        let with_pool_time = this.benchmark_with_pool(iterations)
        print("메모리 풀 사용: " + with_pool_time + "ms")

        let without_pool_time = this.benchmark_without_pool(iterations)
        print("일반 할당: " + without_pool_time + "ms")

        let speedup = (without_pool_time as f64) / (with_pool_time as f64)
        print("속도 향상: " + speedup + "x\n")

        print("✅ GC 사이클 제거!")
        print("✅ 메모리 사용량 안정화!")
        print("✅ 예측 가능한 성능!\n")
    }
}

// ========================================
// 헬퍼 함수
// ========================================

fn __current_time_ms() -> i64 {
    // 현재 시간 (밀리초)
}

