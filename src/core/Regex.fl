    // 내부적으로 캐싱됨
}

// 정규식 매칭
fn regex_match(pattern: RegexPattern, value: string) -> bool {
    // value가 pattern과 일치하는가?
    // 반환: true/false
}

fn regex_test(pattern: string, value: string) -> bool {
    // 패턴 문자열로 직접 테스트 (컴파일 + 매칭)
    let regex = RegexPattern.new(pattern)
    return regex_match(regex, value)
}

