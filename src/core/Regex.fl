// ========================================
// 정규식 컴파일 & 매칭
// ========================================

struct RegexPattern {
    pattern: string,           // 원본 패턴
    compiled: any,             // 컴파일된 정규식 (언어 런타임)
    flags: string = "",        // "i" = case-insensitive, "g" = global

    fn new(pattern: string, flags: string = "") -> RegexPattern {
        return RegexPattern{
            pattern: pattern,
            compiled: __compile_regex(pattern, flags),
            flags: flags
        }
    }
}

// 정규식 컴파일 (런타임 최적화)
fn __compile_regex(pattern: string, flags: string) -> any {
