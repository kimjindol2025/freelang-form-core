// ========================================
// 메시지 포매터
// ========================================

struct I18nFormatter {
    default_locale: string = "ko",
    current_locale: string = "ko",

    fn set_locale(locale: string) {
        this.current_locale = locale
    }

    fn get_locale() -> string {
        return this.current_locale
    }

    fn format_message(code: string, params: map<string, any>? = null) -> string {
        return this.format_message_with_locale(code, this.current_locale, params)
    }

    fn format_message_with_locale(code: string, locale: string, params: map<string, any>? = null) -> string {
        // 1. 메시지 템플릿 조회
        if !MESSAGES.contains(locale) {
            locale = this.default_locale
        }

        let messages = MESSAGES[locale]
        if !messages.contains(code) {
            return code  // 메시지 없으면 코드 반환
        }

        let template = messages[code]

        // 2. 파라미터 치환
        if params != null {
            for (key, value) in params {
                let placeholder = "{" + key + "}"
                template = template.replace(placeholder, value as string)
            }
        }

        return template
    }

    fn format_error(error: ValidationError, locale: string? = null) -> string {
        if locale == null {
            locale = this.current_locale
        }

        // 에러 코드에서 메시지 생성
        // error.code = "MIN_LENGTH", message = "최소 {min}자..."
        // → format_message("min_length", {"min": 3})

        return this.format_message_with_locale(error.code, locale)
    }

    fn format_errors(errors: [ValidationError], locale: string? = null) -> [string] {
        if locale == null {
            locale = this.current_locale
        }

        let formatted: [string] = []
        for error in errors {
            formatted.push(this.format_error(error, locale))
        }
        return formatted
    }

    fn format_validation_result(result: ValidationResult, locale: string? = null) -> map<string, any> {
        if locale == null {
            locale = this.current_locale
        }

        return {
            "is_valid": result.is_valid,
            "errors": this.format_errors(result.errors, locale),
            "message": result.is_valid ?
                this.format_message("form_submitted", locale) :
                this.format_message("form_invalid", locale)
        }
    }
}

// ========================================
// 글로벌 i18n 인스턴스
// ========================================

let i18n = I18nFormatter{
    default_locale: "ko",
    current_locale: "ko"
}

// ========================================
// 헬퍼 함수
// ========================================

fn set_i18n_locale(locale: string) {
    i18n.set_locale(locale)
}

fn t(code: string, params: map<string, any>? = null) -> string {
    return i18n.format_message(code, params)
}

fn t_with_locale(code: string, locale: string, params: map<string, any>? = null) -> string {
    return i18n.format_message_with_locale(code, locale, params)
}

// ========================================
// 사용 예시
// ========================================

// 예 1: 기본 메시지
fn example_basic() {
    set_i18n_locale("ko")
    let msg = t("required")
    print(msg)  // "필수 필드입니다"
}

// 예 2: 파라미터 포함
fn example_with_params() {
    set_i18n_locale("en")
    let msg = t("min_length", {"min": 3})
    print(msg)  // "Minimum 3 characters"
}

// 예 3: 다국어 전환
fn example_multilang() {
    let error = ValidationError{
        field: "username",
        code: "min_length",
        message: "최소 3자"
    }

    print(i18n.format_error(error, "ko"))  // 한국어
    print(i18n.format_error(error, "en"))  // 영어
    print(i18n.format_error(error, "ja"))  // 일본어
}

