// FreeLang Direct-Bind Form Engine
// Phase 2: Internationalization (i18n)
// 다국어 에러 메시지
// 2026-03-08

// ========================================
// 메시지 저장소
// ========================================

struct I18nMessage {
    code: string,              // "REQUIRED", "EMAIL", "MIN_LENGTH"
    locale: string,            // "ko", "en", "ja"
    message: string,           // 메시지 텍스트
    params: map<string, any>?  // {min: 3, max: 20}
}

// 모든 지원 언어
enum SupportedLocale {
    KO = "ko",  // 한국어
    EN = "en",  // 영어
    JA = "ja",  // 일본어
    ZH = "zh",  // 중국어
    ES = "es"   // 스페인어
}

